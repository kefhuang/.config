# Ignore everything by default
*

# Allowed directories
!zsh/
!zsh/**
!vim/
!vim/**
!tmux/
!tmux/**
tmux/plugins/

# Claude Code config (whitelist specific files only)
!claude/
claude/*
!claude/settings.json
!claude/scripts/
!claude/scripts/**
!claude/hooks/
!claude/hooks/**
!claude/CLAUDE.md
!claude/workspace/
!claude/workspace/CLAUDE.md

# Agents (claude/skills -> ../agents/skills symlink)
!agents/
!agents/skills/
!agents/skills/**

# Ghostty config (whitelist specific files only)
!ghostty/
ghostty/*
!ghostty/config

# Allowed root files
!CLAUDE.md
!AGENTS.md
!README.md
!MAC.md
!UBUNTU.md
!.gitignore
