# Ignore everything by default
*

# Allowed directories
!zsh/
!zsh/**
!vim/
!vim/**
!tmux/
!tmux/**
!aerospace/
!aerospace/**
!sketchybar/
!sketchybar/**

# Claude Code config (whitelist specific files only)
!claude/
claude/*
!claude/settings.json
!claude/scripts/
!claude/scripts/**
!claude/commands/
!claude/commands/**
!claude/agents/
!claude/agents/**
!claude/hooks/
!claude/hooks/**
!claude/CLAUDE.md

# Agents (claude/skills -> ../agents/skills symlink)
!agents/
!agents/skills/
!agents/skills/**

# Raycast scripts (whitelist specific files only)
!raycast/
raycast/*
!raycast/scripts/
!raycast/scripts/**

# Ghostty config (whitelist specific files only)
!ghostty/
ghostty/*
!ghostty/config

# Allowed root files
!CLAUDE.md
!README.md
!MAC.md
!UBUNTU.md
!.gitignore
